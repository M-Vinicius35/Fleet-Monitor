datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Vehicle {
  id        String    @id @default(uuid())
  plate     String    @unique
  latitude  Float
  longitude Float
  speed     Float
  updatedAt DateTime  @updatedAt
  history   History[]
}

model History {
  id        String   @id @default(uuid())
  vehicleId String
  latitude  Float
  longitude Float
  timestamp DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}